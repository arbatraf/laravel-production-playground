{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "oleg/laravel-production-playground",
    "type": "project",
    "description": "Production-oriented Laravel showcase for business backoffice systems, APIs, queues, integrations and tests.",
    "keywords": [
        "laravel",
        "backoffice",
        "moonshine",
        "api",
        "queues",
        "testing"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.8",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "./scripts/composer install",
            "./scripts/php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "./scripts/php artisan key:generate",
            "./scripts/php artisan migrate",
            "yarn install",
            "yarn build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "yarn concurrently -c \"#2563EB,#0F172A,#10B981,#F59E0B\" \"./scripts/php artisan serve\" \"./scripts/php artisan queue:listen --tries=1 --timeout=0\" \"./scripts/php artisan pail --timeout=0\" \"yarn dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "composer:validate": "\"$COMPOSER_BINARY\" validate --strict",
        "test": [
            "./scripts/php artisan config:clear --ansi @no_additional_args",
            "./scripts/php artisan test"
        ],
        "architecture": "./scripts/php artisan test --testsuite=Architecture",
        "pint": "./scripts/php vendor/bin/pint",
        "pint:test": "./scripts/php vendor/bin/pint --test",
        "analyse": "./scripts/php vendor/bin/phpstan analyse --debug",
        "check": [
            "@composer:validate",
            "@pint:test",
            "@analyse",
            "@test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "./scripts/php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "./scripts/php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "./scripts/php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "./scripts/php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.5.0"
        },
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
